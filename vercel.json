{
  "buildCommand": "npm run build",
  "outputDirectory": "out",
  "framework": "nextjs",
  "functions": {},
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://flight-tracker-rio-california-production.up.railway.app/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type"
      }
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://flight-tracker-rio-california-production.up.railway.app"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_API_URL": "https://flight-tracker-rio-california-production.up.railway.app"
    }
  }
}